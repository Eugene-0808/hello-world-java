<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>kskbl · zdjd · wkzkbl</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(145deg, #e9f0f5 0%, #d9e2ec 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: system-ui, 'Segoe UI', 'Inter', 'SF Pro Text', 'Roboto', 'Helvetica Neue', sans-serif;
            padding: 1.5rem;
        }

        /* main card container — clean, subtle, focused only on the three lines */
        .sentence-core {
            max-width: 780px;
            width: 100%;
            background: rgba(255, 255, 255, 0.96);
            backdrop-filter: blur(0px);
            border-radius: 2.5rem;
            box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.25), 0 4px 12px rgba(0, 0, 0, 0.05);
            padding: 2.8rem 2rem;
            transition: all 0.2s ease;
            border: 1px solid rgba(255, 255, 255, 0.6);
        }

        /* minimal elegant typography — each sentence stands alone */
        .verse {
            text-align: center;
            line-height: 1.4;
        }

        .line {
            display: block;
            font-weight: 520;
            letter-spacing: -0.01em;
            font-size: clamp(2.2rem, 10vw, 3.8rem);
            margin: 0.65em 0;
            padding: 0.1rem 0;
            color: #1a2c3e;
            transition: transform 0.2s, color 0.2s;
            word-break: keep-all;
            white-space: normal;
        }

        /* subtle punctuation / breathing space — but no extra visible elements */
        .line:first-child {
            margin-top: 0;
        }

        .line:last-child {
            margin-bottom: 0;
        }

        /* delicate hover only for interactive feedback — does not add text, only refinement */
        @media (hover: hover) {
            .line:hover {
                color: #0f2b3b;
                transform: scale(1.01);
                text-shadow: 0 1px 2px rgba(0, 0, 0, 0.02);
            }
        }

        /* extra small devices: comfortable spacing */
        @media (max-width: 520px) {
            .sentence-core {
                padding: 2rem 1.25rem;
            }
            .line {
                margin: 0.5em 0;
                letter-spacing: -0.005em;
            }
        }

        /* preserve absolute minimalism — no decoration, no extra text, only the three required sentences */
        hr, .separator, .extra, .note, .badge, .counter {
            display: none;
        }

        /* ensure screen readers & copy/paste get clean semantic structure */
        .visually-focus {
            outline: none;
        }
    </style>
</head>
<body>
    <main class="sentence-core" role="main" aria-label="Three distinct sentences: kskbl, zdjd, wkzkbl">
        <div class="verse">
            <span class="line">kskbl</span>
            <span class="line">zdjd</span>
            <span class="line">wkzkbl</span>
        </div>
    </main>
</body>
</html>
